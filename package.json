{
  "name": "manhattan-ave-studio",
  "version": "1.0.0",
  "description": "Manhattan Ave Studio — Brooklyn-based custom web development studio.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "dev": "vercel dev",
    "serve": "npx --yes serve@latest .",
    "deploy:preview": "vercel",
    "deploy:prod": "vercel --prod",
    "optimize:images": "node scripts/optimize-images.mjs",
    "lighthouse": "npx --yes @lhci/cli@latest autorun --collect.url=http://localhost:3000 --collect.numberOfRuns=1 || true"
  },
  "devDependencies": {
    "vercel": "latest"
  },
  "optionalDependencies": {
    "sharp": "^0.33.0"
  }
}
